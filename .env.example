# incipit-api environment — copy to .env and fill in.
# .env is gitignored; never commit real tokens.

# --- Providers (all user-supplied or keyless; nothing bundled) ---

# Your OWN Hardcover API token — free, from https://hardcover.app/settings.
# Optional: leave blank to skip Hardcover (Audible + OpenLibrary still work).
# On a shared instance you can leave this blank and let each user's Plex bundle
# forward their own token via the x-hardcover-token header instead.
HARDCOVER_TOKEN=

# A contact (email or URL) for the OpenLibrary User-Agent. OpenLibrary asks for
# one; requests without it can be throttled. No account needed.
OL_CONTACT=you@example.com

# --- Optional tuning (sensible defaults apply if unset) ---

# Host port to publish the API on (what the Plex bundle points api_base_url at).
API_PORT=3000

# Default region when a request doesn't specify one.
DEFAULT_REGION=us

# fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Requests per minute per client IP before a 429 (default 100).
# MAX_REQUESTS=100

# IPs / CIDR ranges exempt from rate limiting — comma-separated, CIDR-aware.
# Set this to the source IP your API sees for the Plex agent so a from-scratch
# library scan (which bursts many requests from one IP) can't 429 itself.
# NOTE: with Docker port publishing the source is often the bridge gateway
# (e.g. 172.x.0.1), NOT the Plex host's LAN IP — check the API container logs
# for the request `remoteAddress` and allowlist that. Unset → everyone limited.
# RATE_LIMIT_ALLOWLIST=

# Audible chapter support binds a real Audible account and is NOT needed for
# matching or metadata — leave unset unless you specifically want chapters.
# ADP_TOKEN=
# PRIVATE_KEY=
